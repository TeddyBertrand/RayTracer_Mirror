camera:
{
    type = "perspective";
    width = 10000;
    height = 10000;
    position = { x = 0.0; y = 2.0; z = 12.0; };
    look_at = { x = 0.0; y = 0.5; z = 0.0; };
    up = { x = 0.0; y = 1.0; z = 0.0; };
    fieldOfView = 60.0;
};

materials: (
    { id = "gold"; type = "flat_color"; color = { r = 0.8; g = 0.6; b = 0.2; }; },
    { id = "glass"; type = "flat_color"; color = { r = 1.0; g = 1.0; b = 1.0; }; ref = 1.5; },
    { id = "obsidian"; type = "flat_color"; color = { r = 0.05; g = 0.05; b = 0.05; }; },
    { id = "ruby"; type = "flat_color"; color = { r = 0.9; g = 0.1; b = 0.1; }; },
    { id = "ice"; type = "flat_color"; color = { r = 0.9; g = 0.9; b = 1.0; }; ref = 1.31; },
    { id = "white_wall"; type = "flat_color"; color = { r = 0.9; g = 0.9; b = 0.9; }; }
);

shapes: (
    # LE SOL (Noir infini)
    { type = "plane"; position = { x = 0.0; y = 0.0; z = 0.0; }; rotation = { x = 0.0; y = 0.0; z = 0.0; }; material = "obsidian"; },
    
    # LE MUR DE FOND (Lointain)
    { type = "plane"; position = { x = 0.0; y = 0.0; z = -20.0; }; rotation = { x = 90.0; y = 0.0; z = 0.0; }; material = "white_wall"; },

    { type = "cone"; position = { x = 0.0; y = 2.0; z = 0.0; }; rotation = { x = 0.0; y = 0.0; z = 180.0; }; material = "gold"; },

    { type = "cone"; position = { x = -7.0; y = 4.0; z = 0.0; }; rotation = { x = 0.0; y = 0.0; z = 90.0; }; material = "gold"; },

    { type = "cone"; position = { x = 7.0; y = 4.0; z = 0.0; }; rotation = { x = 0.0; y = -0.0; z = 270.0; }; material = "gold"; },

    { type = "cone"; position = { x = 7.0; y = 4.0; z = 0.0; }; rotation = { x = 0.0; y = -0.0; z = 270.0; }; material = "gold"; },

    { type = "sphere"; position = { x = 0.0; y = 4.0; z = 0.0; }; radius = 1.0; material = "gold"; }

);

lights: (
    { type = "point"; position = { x = 5.0; y = 5.0; z = 0.0; }; color = { r = 255.0; g = 0.0; b = 0.0; }; intensity = 0.7 },
    
    { type = "point"; position = { x = -5.0; y = 5.0; z = 0.0; }; color = { r = 0.0; g = 0.0; b = 255.0; }; intensity = 0.7 },

    { type = "point"; position = { x = 0.0; y = 3.0; z = 2.0; }; color = { r = 100.0; g = 255.0; b = 100.0; }; intensity = 0.01 },

);

sky = {
    type = "galaxy";
    nebulaColor = { r = 0.1; g = 0.0; b = 0.3; }; # Un violet profond
};
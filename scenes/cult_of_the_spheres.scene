camera:
{
    type = "perspective";
    width = 1920;
    height = 1080;
    position = { x = 0.0; y = 2.0; z = 12.0; };
    look_at = { x = 0.0; y = 0.5; z = 0.0; };
    up = { x = 0.0; y = 1.0; z = 0.0; };
    fieldOfView = 60.0;
};

materials: (
    { id = "gold"; type = "lambertian"; color = { r = 0.8; g = 0.6; b = 0.2; }; },
    { id = "glass"; type = "transparent"; color = { r = 1.0; g = 1.0; b = 1.0; }; ref = 1.5; },
    { id = "obsidian"; type = "lambertian"; color = { r = 0.05; g = 0.05; b = 0.05; }; },
    { id = "ruby"; type = "lambertian"; color = { r = 0.9; g = 0.1; b = 0.1; }; },
    { id = "ice"; type = "transparent"; color = { r = 0.9; g = 0.9; b = 1.0; }; ref = 1.31; },
    { id = "white_wall"; type = "lambertian"; color = { r = 0.9; g = 0.9; b = 0.9; }; }
);

shapes: (
    # LE SOL (Noir infini)
    { type = "plane"; position = { x = 0.0; y = 0.0; z = 0.0; }; normal = { x = 0.0; y = 1.0; z = 0.0; }; material = "obsidian"; },
    
    # LE MUR DE FOND (Lointain)
    { type = "plane"; position = { x = 0.0; y = 0.0; z = -20.0; }; normal = { x = 0.0; y = 0.0; z = 1.0; }; material = "white_wall"; },

    # RANGÉE DE GAUCHE (Sphères de verre/glace)
    { type = "sphere"; position = { x = -2.5; y = 0.75; z = 6.0; }; radius = 0.75; material = "glass"; },
    { type = "sphere"; position = { x = -2.5; y = 0.75; z = 3.0; }; radius = 0.75; material = "ice"; },
    { type = "sphere"; position = { x = -2.5; y = 0.75; z = 0.0; }; radius = 0.75; material = "glass"; },
    { type = "sphere"; position = { x = -2.5; y = 0.75; z = -3.0; }; radius = 0.75; material = "ice"; },
    { type = "sphere"; position = { x = -2.5; y = 0.75; z = -6.0; }; radius = 0.75; material = "glass"; },

    # RANGÉE DE DROITE (Sphères d'or et rubis alternées)
    { type = "sphere"; position = { x = 2.5; y = 0.75; z = 6.0; }; radius = 0.75; material = "gold"; },
    { type = "sphere"; position = { x = 2.5; y = 0.75; z = 3.0; }; radius = 0.75; material = "ruby"; },
    { type = "sphere"; position = { x = 2.5; y = 0.75; z = 0.0; }; radius = 0.75; material = "gold"; },
    { type = "sphere"; position = { x = 2.5; y = 0.75; z = -3.0; }; radius = 0.75; material = "ruby"; },
    { type = "sphere"; position = { x = 2.5; y = 0.75; z = -6.0; }; radius = 0.75; material = "gold"; },

    # L'OBJET CENTRAL (Grosse sphère de verre suspendue)
    { type = "sphere"; position = { x = 0.0; y = 3.0; z = -2.0; }; radius = 2.0; material = "glass"; }
);

lights: (
    # Key Light (Haut Droite)
    { type = "point"; position = { x = 15.0; y = 15.0; z = 10.0; }; color = { r = 255.0; g = 240.0; b = 200.0; }; intensity = 0.4 },
    
    # Fill Light (Bleue, Gauche)
    { type = "point"; position = { x = -15.0; y = 5.0; z = 5.0; }; color = { r = 100.0; g = 150.0; b = 255.0; }; intensity = 0.3 },
    
    # Back Light (Contre-jour pour souligner les silhouettes de verre)
    { type = "point"; position = { x = 0.0; y = 10.0; z = -15.0; }; color = { r = 255.0; g = 255.0; b = 255.0; }; intensity = 0.2 }
);

sky = {
    type = "galaxy";
    nebulaColor = { r = 0.1; g = 0.0; b = 0.3; }; # Un violet profond
};